        {
            "id": "task_3",
            "title": "4.03: Vergelijkings-operatoren",
            "instruction": "<b style=\"color: rgb(51, 65, 85); font-size: 0.875rem;\">Vergelijkings-operatoren</b><span style=\"color: rgb(51, 65, 85); font-size: 0.875rem;\">&nbsp;gebruiken we om waardes te vergelijken . Afhankelijk van de vergelijking komt er </span><code class=\"bg-slate-100 dark:bg-slate-950 px-1 py-0.5 rounded text-amber-600 dark:text-amber-400 font-mono text-xs\">True</code><span style=\"color: rgb(51, 65, 85); font-size: 0.875rem;\"> uit of </span><code class=\"bg-slate-100 dark:bg-slate-950 px-1 py-0.5 rounded text-amber-600 dark:text-amber-400 font-mono text-xs\">False</code><span style=\"color: rgb(51, 65, 85); font-size: 0.875rem;\">.</span><br><table class=\"wysiwyg-table w-full border-collapse border border-slate-800 my-4 text-xs md:text-sm bg-slate-950/20\" style=\"border-radius: 8px; overflow: hidden;\"><thead><tr class=\"bg-slate-900\"><th class=\"border border-slate-800 p-2 text-left font-bold text-slate-200\">Symbool</th>\n                            <th class=\"border border-slate-800 p-2 text-left font-bold text-slate-200\">Uitleg</th>\n                        <th class=\"border border-slate-800 p-2 text-left font-bold text-slate-200\">Voorbeeld</th><th class=\"border border-slate-800 p-2 text-left font-bold text-slate-200\">Uitkomst</th></tr><tr><td class=\"border border-slate-800 p-2 text-slate-300\">&gt;</td><td class=\"border border-slate-800 p-2 text-slate-300\">Groter dan</td><td class=\"border border-slate-800 p-2 text-slate-300\">3 &gt; 1</td><th class=\"border border-slate-800 p-2 text-left font-bold text-slate-200\"><span style=\"font-weight: normal;\">True</span></th></tr>\n                    </thead>\n                    <tbody>\n                        <tr>\n                            <td class=\"border border-slate-800 p-2 text-slate-300\">&lt;</td>\n                            <td class=\"border border-slate-800 p-2 text-slate-300\">Kleiner dan</td>\n                        <td class=\"border border-slate-800 p-2 text-slate-300\">3 &lt; 1</td><td class=\"border border-slate-800 p-2 text-slate-300\"><span style=\"font-size: 0.875rem; background-color: rgba(241, 245, 249, 0.5);\"><font color=\"#475569\">False</font></span><span style=\"color: rgb(51, 65, 85); font-size: 0.875rem; background-color: rgb(248, 250, 252);\">&nbsp;</span></td></tr><tr><td class=\"border border-slate-800 p-2 text-slate-300\">==</td><td class=\"border border-slate-800 p-2 text-slate-300\">Gelijk aan</td><td class=\"border border-slate-800 p-2 text-slate-300\">3 == 1</td><td class=\"border border-slate-800 p-2 text-slate-300\">False</td></tr><tr><td class=\"border border-slate-800 p-2 text-slate-300\">!=</td><td class=\"border border-slate-800 p-2 text-slate-300\">Ongelijk aan</td><td class=\"border border-slate-800 p-2 text-slate-300\">3 != 1</td><td class=\"border border-slate-800 p-2 text-slate-300\">True</td></tr><tr><td class=\"border border-slate-800 p-2 text-slate-300\">&gt;=</td><td class=\"border border-slate-800 p-2 text-slate-300\">Groter of gelijk aan</td><td class=\"border border-slate-800 p-2 text-slate-300\">3 &gt;= 1</td><td class=\"border border-slate-800 p-2 text-slate-300\">True</td></tr><tr><td class=\"border border-slate-800 p-2 text-slate-300\">&lt;=</td><td class=\"border border-slate-800 p-2 text-slate-300\">Kleiner of gelijk aan</td><td class=\"border border-slate-800 p-2 text-slate-300\">3 &lt;= 1<br></td><td class=\"border border-slate-800 p-2 text-slate-300\">False</td></tr></tbody></table><ul class=\"list-disc pl-6 space-y-1 mt-1 mb-2\">\n</ul>\n<div class=\"wysiwyg-section-uitvoeren my-3\" style=\"color: rgb(51, 65, 85); font-size: 0.875rem; display: inline !important;\"><div class=\"font-semibold flex items-center gap-2 mb-1 text-slate-700 dark:text-slate-200 text-sm select-none\" style=\"display: inline !important;\"><i class=\"fa-solid fa-play text-emerald-400\"></i> Uitvoeren:</div></div><div><ol class=\"list-decimal pl-6 space-y-1 mt-1 mb-2\"><li><span style=\"color: rgb(51, 65, 85); font-size: 0.875rem;\">Bekijk de code hiernaast en probeer te voorspellen wat de uitkomst zal zijn.</span></li>\n  <li>Start het programma en kijk of je gelijk hebt.</li>\n</ol>\n</div>",
